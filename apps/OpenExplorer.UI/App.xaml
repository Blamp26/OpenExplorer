<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OpenExplorer_UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenExplorer_UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary>
                    <SolidColorBrush x:Key="OpenExplorerAccentBrush" Color="#2563EB" />
                    <SolidColorBrush x:Key="OpenExplorerDetailsHeaderBackground" Color="#0A000000" />
                    <SolidColorBrush x:Key="OpenExplorerDetailsRowBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="OpenExplorerDetailsRowHoverBackground" Color="#10000000" />
                    <SolidColorBrush x:Key="OpenExplorerDetailsSelectionBackground" Color="#220078D4" />
                    <SolidColorBrush x:Key="OpenExplorerDetailsFocusBorder" Color="#0078D4" />
                    <SolidColorBrush x:Key="OpenExplorerDiagnosticsBackground" Color="#08000000" />
                    <SolidColorBrush x:Key="OpenExplorerSubtleSeparatorBrush" Color="#24000000" />
                    <Style x:Key="OpenExplorerPageTitleTextStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="28" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
                    <Style x:Key="OpenExplorerSecondaryTextStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="14" /><Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" /></Style>
                    <Style x:Key="OpenExplorerDiagnosticsTextStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="13" /><Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" /></Style>
                    <Style x:Key="OpenExplorerDetailsHeaderTextStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="13" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="VerticalAlignment" Value="Center" /></Style>
                    <Style x:Key="OpenExplorerDetailsRowTextStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="13" /><Setter Property="VerticalAlignment" Value="Center" /><Setter Property="TextTrimming" Value="CharacterEllipsis" /></Style>
                    <x:Double x:Key="OpenExplorerDetailsHeaderHeight">34</x:Double>
                    <x:Double x:Key="OpenExplorerDetailsRowHeight">32</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
