<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenExplorer_UI.Features.FileView.Details.VirtualizedDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:application="using:OpenExplorer.Application.Diagnostics"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
        <Grid MinWidth="760">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Padding="16,0" Background="#0A000000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="300" Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Name" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Date modified" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Type" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Size" TextAlignment="Right" />
            </Grid>
            <controls:ItemsRepeater x:Name="DetailsRepeater" Grid.Row="1" ItemsSource="{x:Bind Items, Mode=OneTime}">
                <controls:ItemsRepeater.Layout>
                    <controls:StackLayout Orientation="Vertical" />
                </controls:ItemsRepeater.Layout>
                <controls:ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="application:SyntheticFileItem">
                        <Grid Height="32" Padding="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MinWidth="300" Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneTime}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind DateModifiedText, Mode=OneTime}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind TypeText, Mode=OneTime}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind SizeText, Mode=OneTime}" TextAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </controls:ItemsRepeater.ItemTemplate>
            </controls:ItemsRepeater>
        </Grid>
    </ScrollViewer>
</UserControl>
