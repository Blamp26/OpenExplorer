<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FastExplorer_UI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="32" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" FontSize="28" FontWeight="SemiBold" Text="FastExplorer" />
        <TextBlock x:Name="VersionText" Grid.Row="1" FontSize="16" Text="Initializing native engine..." />
    </Grid>
</Page>
